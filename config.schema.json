{
    "pluginAlias": "esphome-hv2",
    "pluginType": "platform",
    "singular": true,
    "schema": {
        "type": "object",
        "properties": {
            "devices": {
                "title": "Devices",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "host": {
                            "title": "Host (IP Address)",
                            "type": "string",
                            "description": "The IP address or hostname of your ESP device."
                        },
                        "port": {
                            "title": "Port",
                            "type": "number",
                            "default": 6053,
                            "required": false
                        },
                        "encryptionKey": {
                            "title": "Encryption Key (Noise)",
                            "type": "string",
                            "description": "The 32-character encryption key found in your ESPHome YAML under 'api: encryption: key:'.",
                            "required": false
                        },
                        "password": {
                            "title": "API Password (Legacy)",
                            "type": "string",
                            "description": "Only use this if you are using the older 'password' authentication method.",
                            "required": false
                        }
                    }
                }
            },
            "debug": {
                "title": "Debug Mode",
                "type": "boolean",
                "required": false,
                "description": "Enable this to see detailed logs in the Homebridge console."
            },
            "discover": {
                "title": "Discover devices (mDNS)",
                "type": "boolean",
                "required": false,
                "description": "Automatically find devices on your local network using mDNS."
            }
        }
    },
    "form": [
        {
            "type": "section",
            "title": "Device Configuration",
            "expandable": true,
            "expanded": true,
            "items": [
                {
                    "key": "devices",
                    "items": [
                        "devices[].host",
                        "devices[].port",
                        {
                            "key": "devices[].encryptionKey",
                            "type": "password"
                        },
                        "devices[].password"
                    ]
                }
            ]
        },
        "debug",
        "discover"
    ]
}